# ====================================================
# VARIABLES DE ENTORNO PARA PRODUCCIÓN
# Copiar como .env y completar con valores reales
# NUNCA subir .env a un repositorio público
# ====================================================

# --- Base de datos (PostgreSQL en Docker) ---
DB_USER=voltadmin
DB_PASSWORD=escribe_aqui_una_clave_larga_y_segura_123!
DB_NAME=voltashop_prod

# --- Seguridad JWT (mínimo 64 caracteres aleatorios) ---
SECRET_KEY=genera_aqui_64_caracteres_al_azar_para_blindar_el_login_xxxxxxxx

# --- URLs del sistema ---
# En producción: el dominio real donde corre la tienda (sin barra final)
FRONTEND_URL=https://voltashop.cl
# Orígenes CORS permitidos (separados por coma)
ALLOWED_ORIGINS=https://voltashop.cl,https://www.voltashop.cl

# --- Email (mail.conectaai.cl) ---
CONECTAAI_API_KEY=sk_live_tu_apikey_de_mail_conectaai_aqui
CONECTAAI_API_URL=https://mail.conectaai.cl/api/send
# Correo donde recibes alertas de nueva venta
ADMIN_EMAIL=tu_correo@gmail.com

# --- MercadoPago (Chile) ---
# Token de PRODUCCIÓN (empieza con APP_USR-...)
# Obtener en: https://www.mercadopago.cl/developers/panel/app
MP_ACCESS_TOKEN=APP_USR-tu_token_de_produccion_de_mercadopago_aqui

# --- Automatización WhatsApp vía n8n ---
# URL del nodo Webhook inicial en n8n.conectaai.cl
N8N_WEBHOOK_URL=https://n8n.conectaai.cl/webhook/voltashop-orders

# --- Modo demo (solo en desarrollo) ---
# Poner true para que aparezca un producto de demo al arrancar con DB vacía
SEED_DEMO_DATA=false
